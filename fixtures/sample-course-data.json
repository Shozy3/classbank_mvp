                },
                {
                  "flashcard_id": "fc-race-002",
                  "front_rich_text": "<p>What is a critical section?</p>",
                  "back_rich_text": "<p>A portion of code that accesses shared state and requires mutual exclusion.</p>",
                  "reference_text": "Lecture notes: critical sections",
                  "created_at": "2026-03-09T12:00:00Z",
